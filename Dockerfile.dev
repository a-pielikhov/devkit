FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    make \
    curl \
    gcc \
    python3-dev \
    zsh \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

# Pre-configure zsh to load completions from ~/.zfunc
RUN printf 'fpath=(~/.zfunc $fpath)\nautoload -Uz compinit && compinit\n' > /root/.zshrc

WORKDIR /workspace
